# tsctl configuration — copy to ".env" (gitignored) and fill in.
# docker compose reads ".env" automatically. All values are also plain flags
# (see "tsctl serve -h"); the env names below are the canonical ones.

# === Tailscale enrollment (REQUIRED for first run; remove afterwards) =========
# tsctl joins your tailnet as a tagged node (tag:tsctl). Provide ONE of:
#   - an OAuth client secret (recommended, never expires): create an OAuth client
#     in the Tailscale admin console with the `auth_keys` scope owning tag:tsctl,
#     and use its tskey-client-... secret here; or
#   - a tagged auth key: Settings -> Keys -> Generate, add tag:tsctl (and enable
#     "Pre-approved" if device approval is on), use the tskey-auth-... value.
# After the node registers, its key persists in the tsctl-state volume and this
# is no longer used — you can blank it out. (An API token tskey-api-... will NOT
# work for enrollment.)
TS_AUTHKEY=tskey-client-xxxxxxxxxxxx

# === App authorization (need AT LEAST ONE auth method) =======================
# tsctl admits a request via EITHER path:
#   - tailnet path: the single tailnet login (email) allowed to view/control via
#     the web UI. Everyone else on the tailnet is denied (fail-closed). Must
#     match your Tailscale identity exactly. Leave blank to use ONLY the password
#     path below.
TSCTL_OWNER=you@example.com
#   - password path: a shared password for reaching the UI on a published host
#     port (see TSCTL_HTTP_LISTEN). REQUIRED whenever TSCTL_HTTP_LISTEN is set —
#     tsctl refuses to expose an unauthenticated control UI on a host socket.
#     Sessions are signed cookies; restarting tsctl invalidates them (sign in
#     again). Use a strong, unique value.
# TSCTL_UI_PASSWORD=change-me-to-a-strong-password

# Comma-separated 100.x IPv4 addresses of the OpenWRT routers you manage.
# OPTIONAL: leave empty to auto-discover every tag:router node from the netmap;
# set it only to pin an explicit subset.
# TSCTL_ROUTERS=100.64.0.10,100.64.0.11

# === Host-port UI (optional; reach the UI from your LAN) ======================
# Serve the SAME UI+API on a HOST socket in addition to the tailnet, so you can
# open it from a LAN browser without joining the tailnet. Off by default. When
# set you MUST also set TSCTL_UI_PASSWORD (above) and add the hostname/IP you
# browse to in TSCTL_ALLOWED_HOSTS (below). The tailnet path keeps working.
# TSCTL_HTTP_LISTEN=:8080
#
# Host-header allowlist (DNS-rebinding defense). The tsnet hostname, its MagicDNS
# FQDN and 100.x are trusted automatically, and the TSCTL_HTTP_LISTEN host is
# added for you — but you MUST add the NAS hostname/IP you actually browse to,
# WITHOUT the port (e.g. nas.local,192.168.1.50). Comma-separated.
# TSCTL_ALLOWED_HOSTS=nas.local,192.168.1.50

# === Optional ================================================================
# Hostname the node presents (and the URL you open: http://<hostname>/).
TSCTL_HOSTNAME=tsctl
# SSH login on the routers (OpenWRT is root in v1).
TSCTL_SSH_USER=root
# Manage the router's --exit-node-allow-lan-access: preserve|true|false.
# "preserve" (default) never changes it (or any other tailscale-up setting).
TSCTL_EXIT_NODE_LAN_ACCESS=preserve
# Extra Host header values to allow (DNS-rebinding defense), comma-separated.
# The tsnet hostname, its MagicDNS FQDN and 100.x are trusted automatically.
# TSCTL_ALLOWED_HOSTS=
# Refresh cadence while a browser is connected.
# TSCTL_POLL_INTERVAL=30s
# Verbose tsnet backend logs (any non-empty value enables).
# TSCTL_DEBUG=

# === Router transport (DEFAULT: tailscale-ssh) ===============================
# How tsctl reaches a router to read/set its exit node. Leave UNSET for the
# default, "tailscale-ssh": SSH over the tailnet with `none` auth, gated by the
# ACL — no router-side password, host keys are implicitly trusted because
# WireGuard already authenticates the peer.
#
# The OPT-IN alternative, "ip-password", SSHes to the router's LAN IP with a
# shared password instead. Caveats — read before enabling:
#   * It trades Tailscale's ACL-governed, per-identity, revocable access for a
#     flat reusable root secret with no central revocation or audit trail. Only
#     reasonable on a trusted, single-operator LAN. KEYS STILL BEAT PASSWORDS.
#   * Over plain LAN there is no WireGuard peer auth, so an unverified host key
#     lets a MITM harvest the password — host-key verification is MANDATORY and
#     on by default (tofu). Do NOT use "insecure" except for throwaway testing.
#   * The 100.x stays each router's identity everywhere; you must map each one to
#     its LAN endpoint in TSCTL_ROUTER_ADDRS (an unmapped router fails loudly).
# TSCTL_ROUTER_TRANSPORT=ip-password
#
# Host-key verification mode for ip-password:
#   tofu     (default) trust-on-first-use: record a new router's key in
#            $TSCTL_STATE_DIR/known_hosts and accept; a CHANGED key is refused
#            hard (possible MITM) and never auto-trusted.
#   strict   accept only keys already present in known_hosts (pre-seed it).
#   pin      v1: same as strict against a pre-seeded per-router entry.
#   insecure NO host-key verification (logs a startup warning). Avoid.
# TSCTL_ROUTER_HOSTKEY_MODE=tofu
#
# Map each router's 100.x identity to the LAN endpoint to SSH to. Comma-separated
# 100.x=host[:port] pairs (":22" assumed when no port is given).
# TSCTL_ROUTER_ADDRS=100.64.0.10=192.168.1.1,100.64.0.11=192.168.1.2:2222
#
# The router SSH password is a SECRET and is NOT a flag. Provide it via env (here)
# or, in production, via systemd LoadCredential ($CREDENTIALS_DIRECTORY/ssh_password
# on tmpfs) / a Docker secret read through CREDENTIALS_DIRECTORY — never logged.
# Required only when TSCTL_ROUTER_TRANSPORT=ip-password.
# TSCTL_SSH_PASSWORD=change-me-to-the-router-root-password
