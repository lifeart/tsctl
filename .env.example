# tsctl configuration — copy to ".env" (gitignored) and fill in.
# docker compose reads ".env" automatically. All values are also plain flags
# (see "tsctl serve -h"); the env names below are the canonical ones.

# === Tailscale enrollment (REQUIRED for first run; remove afterwards) =========
# tsctl joins your tailnet as a tagged node (tag:tsctl). Provide ONE of:
#   - an OAuth client secret (recommended, never expires): create an OAuth client
#     in the Tailscale admin console with the `auth_keys` scope owning tag:tsctl,
#     and use its tskey-client-... secret here; or
#   - a tagged auth key: Settings -> Keys -> Generate, add tag:tsctl (and enable
#     "Pre-approved" if device approval is on), use the tskey-auth-... value.
# After the node registers, its key persists in the tsctl-state volume and this
# is no longer used — you can blank it out. (An API token tskey-api-... will NOT
# work for enrollment.)
TS_AUTHKEY=tskey-client-xxxxxxxxxxxx

# === App authorization (REQUIRED) ============================================
# The single tailnet login (email) allowed to view/control via the web UI.
# Everyone else on the tailnet is denied (fail-closed). Must match your
# Tailscale identity exactly.
TSCTL_OWNER=you@example.com

# Comma-separated 100.x IPv4 addresses of the OpenWRT routers you manage.
TSCTL_ROUTERS=100.64.0.10,100.64.0.11

# === Optional ================================================================
# Hostname the node presents (and the URL you open: http://<hostname>/).
TSCTL_HOSTNAME=tsctl
# SSH login on the routers (OpenWRT is root in v1).
TSCTL_SSH_USER=root
# Manage the router's --exit-node-allow-lan-access: preserve|true|false.
# "preserve" (default) never changes it (or any other tailscale-up setting).
TSCTL_EXIT_NODE_LAN_ACCESS=preserve
# Extra Host header values to allow (DNS-rebinding defense), comma-separated.
# The tsnet hostname, its MagicDNS FQDN and 100.x are trusted automatically.
# TSCTL_ALLOWED_HOSTS=
# Refresh cadence while a browser is connected.
# TSCTL_POLL_INTERVAL=30s
# Verbose tsnet backend logs (any non-empty value enables).
# TSCTL_DEBUG=
